{
  "name": "@fmms/workstation-client",
  "version": "0.1.0",
  "private": true,
  "description": "FMMS 工位客户端 (Electron) — 双屏 webview + 本地配置页 + 采集转发",
  "main": "dist-electron/app-workstation-client/electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k -n VITE,TSC,ELECTRON -c blue,cyan,magenta \"vite build --watch\" \"tsc -p electron/tsconfig.json --watch --preserveWatchOutput\" \"wait-on ./dist/index.html ./dist-electron/app-workstation-client/electron/main.js && electron .\"",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "typecheck": "tsc -p electron/tsconfig.json --noEmit && tsc --noEmit",
    "lint": "eslint src electron --ext .ts,.tsx",
    "start": "electron ."
  },
  "dependencies": {
    "@fmms/shared": "workspace:*",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "antd": "^6.4.4",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^5.9.0-beta.0",
    "vite": "^8.0.12",
    "wait-on": "^8.0.0"
  }
}
