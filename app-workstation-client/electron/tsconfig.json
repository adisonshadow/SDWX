{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../..",
    "outDir": "../dist-electron",
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": false,
    "declaration": false,
    "sourceMap": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true
  },
  "include": ["./**/*.ts", "../../packages/shared/src/**/*.ts"]
}
