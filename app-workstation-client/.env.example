# 工位客户端 — 环境变量模板
# 复制为 .env.development（开发）或 .env.production（生产）
# 注意：实际运行时配置存于 electron-store（用户在配置页填写），优先级高于此文件

DEFAULT_OP_BASE_URL=http://localhost:5181
DEFAULT_EADAF_FRONTEND_URL=http://localhost:9527
DEFAULT_SSO_APPLICATION_ID=10000000-0001-4000-8000-000000000006

# 开发：true（mock 采集驱动，无需真实硬件）；生产：false
USE_MOCK_DRIVER=true
