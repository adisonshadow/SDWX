# 故检修理线系统 (FMMS) — 根环境变量说明
#
# 各子包独立管理自己的环境变量，参见：
#   admin/backend/.env.example        — BFF（含敏感密钥，按 NODE_ENV 加载）
#   admin/frontend/.env.example       — 前端（Vite 按 mode 加载，仅公开变量）
#   app-workstation-client/.env.example — Electron 客户端（默认值，运行时存 electron-store）
#
# 端口分配：
#   EADAF        9527
#   admin/backend (BFF)  5180
#   admin/frontend       5181
#   配置页（dev）        5182

# ============ EADAF 平台（开发环境） ============
EADAF_API_BASE_URL=http://localhost:9527
EADAF_FRONTEND_URL=http://localhost:9527

# ============ FMMS 应用 ============
FMMS_APP_CODE=FMMS
FMMS_APPLICATION_ID=10000000-0001-4000-8000-000000000006
# app_secret 仅 admin/backend 使用，从 EADAF 三方应用「密钥管理」获取
# 请填入 admin/backend/.env.development（开发）或 .env.production（生产）
FMMS_APP_SECRET=

# ============ SSO ============
# JWT 签名盐值，与 EADAF SSO 配置中的「签名盐值」一致
SSO_JWT_SALT=
SSO_REDIRECT_MODE=POST_REDIRECT
SSO_CALLBACK_URL=http://localhost:5180/auth/callback
