# admin/frontend — 环境变量模板
# Vite 按 mode 自动加载：.env.development（vite dev）/ .env.production（vite build）
# VITE_ 前缀变量会暴露到前端，切勿放密钥

# BFF API 基址 (开发时经 vite proxy 转发到 localhost:5180；生产用反向代理路径)
VITE_API_BASE=/api

# EADAF 前端地址 (SSO 登录入口)
VITE_SSO_EADAF_FRONTEND=http://localhost:9527

# FMMS 应用 ID
VITE_SSO_APPLICATION_ID=10000000-0001-4000-8000-000000000006
