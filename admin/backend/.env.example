# admin/backend (BFF) — 环境变量模板
# 复制为 .env.development（开发）或 .env.production（生产）并填写
# dotenv 按 NODE_ENV 加载：production → .env.production，其他 → .env.development

# ---- EADAF ----
EADAF_API_BASE_URL=http://localhost:9527
EADAF_FRONTEND_URL=http://localhost:9527
FMMS_APP_CODE=FMMS
FMMS_APPLICATION_ID=10000000-0001-4000-8000-000000000006
# 64 位十六进制密钥，从 EADAF 三方应用「密钥管理」获取
FMMS_APP_SECRET=
# 向 EADAF 管理员索要初始 token；首次换取后 BFF 自动用旧 token 刷新，不再依赖此项

# ---- SSO ----
# 与 EADAF SSO 配置中的「签名盐值」一致
SSO_JWT_SALT=
SSO_REDIRECT_MODE=POST_REDIRECT
SSO_CALLBACK_URL=http://localhost:5180/auth/callback

# ---- BFF ----
BFF_PORT=5180
BFF_CORS_ORIGIN=http://localhost:5181

