{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "declaration": false,
    "sourceMap": true,
    "lib": ["ES2022"],
    "paths": {
      "@fmms/shared": ["../../packages/shared/src/index.ts"],
      "@fmms/shared/*": ["../../packages/shared/src/*"]
