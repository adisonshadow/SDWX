{
  "name": "@fmms/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FMMS admin/backend — stateless BFF (no database), data lives in EADAF",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_ENV=production node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@fmms/shared": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0-beta.0"
  }
}
